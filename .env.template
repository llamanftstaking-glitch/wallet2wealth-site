# =====================================================================
# Wallet to Wealth — environment template
# Copy to .env and fill in secrets. Never commit .env.
# =====================================================================

# Public site URL (used in OG tags, email links, signed download URLs)
NEXT_PUBLIC_SITE_URL=https://wallet2wealth.com

# ---------------------------------------------------------------------
# PocketBase backend
# ---------------------------------------------------------------------
# Where the Next.js app reaches PocketBase. Defaults to 127.0.0.1:8090 in dev.
POCKETBASE_URL=http://127.0.0.1:8090
# Superuser created on first PocketBase boot (admin UI at /_/).
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# ---------------------------------------------------------------------
# Stripe — checkout + webhook
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------
# Transactional email (PDF delivery + receipts). Use one provider.
# Resend recommended (https://resend.com).
# ---------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Wallet to Wealth <hello@wallet2wealth.com>"

# ---------------------------------------------------------------------
# Analytics / ad pixels (all optional, public)
# ---------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
