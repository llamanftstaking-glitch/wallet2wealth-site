# =====================================================================
# Wallet to Wealth — environment template
# Copy to .env (or set in Replit Secrets). Never commit real values.
# =====================================================================

# Public site URL (OG tags, email links, signed download URLs)
NEXT_PUBLIC_SITE_URL=https://wallet2wealth.com

# ---------------------------------------------------------------------
# Supabase (managed Postgres)
# ---------------------------------------------------------------------
# Server-only — bypasses RLS, never expose to browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Safe for browser (used by future client-side reads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------
# Stripe — checkout + webhook
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------
# Transactional email (PDF delivery + receipts). Resend recommended.
# ---------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Wallet to Wealth <hello@wallet2wealth.com>"

# ---------------------------------------------------------------------
# Analytics / ad pixels (all optional, public)
# ---------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
