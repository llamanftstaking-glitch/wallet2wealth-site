# Replit configuration — Wallet to Wealth (Next.js + Supabase)
# Reserved VM. Supabase handles persistence; no sidecars needed.

modules = ["nodejs-20", "bash"]
run = "pnpm start"

hidden = [".config", ".next", "node_modules", ".trash", ".cache"]

[nix]
channel = "stable-24_05"

[env]
NEXT_TELEMETRY_DISABLED = "1"

[packager]
language = "nodejs"

[packager.features]
enabledForHosting = false
packageSearch = true
guessImports = true

[unitTest]
language = "nodejs"

[deployment]
deploymentTarget = "vm"
build = ["sh", "-c", "pnpm install --frozen-lockfile && pnpm build"]
run = ["sh", "-c", "pnpm start"]
