{
  "name": "wallet2wealth-site",
  "version": "0.1.0",
  "description": "Wallet to Wealth — crypto education tripwire sales site",
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "dev": "concurrently -n web,pb -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:pb\"",
    "dev:web": "next dev --webpack -p 3333",
    "dev:pb": "pocketbase/pocketbase serve --http=127.0.0.1:8090 --dir=pocketbase/pb_data --hooksDir=pocketbase/pb_hooks --migrationsDir=pocketbase/pb_migrations",
    "pb:install": "bash pocketbase/download.sh",
    "pb:migrate": "pocketbase/pocketbase migrate up --dir=pocketbase/pb_data --migrationsDir=pocketbase/pb_migrations",
    "build": "next build --webpack",
    "postbuild": "node scripts/clean-cache.cjs",
    "start": "concurrently -n web,pb -c cyan,magenta \"pnpm start:web\" \"pnpm start:pb\"",
    "start:web": "next start -p 3333",
    "start:pb": "pocketbase/pocketbase serve --http=0.0.0.0:8090 --dir=pocketbase/pb_data --hooksDir=pocketbase/pb_hooks --migrationsDir=pocketbase/pb_migrations",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint --cache --max-warnings 0 .",
    "lint:prettier": "prettier --cache --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "prettier": "bun run lint:prettier --write",
    "prepare": "husky"
  },
  "homepage": "https://wallet2wealth.com",
  "dependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@glidejs/glide": "^3.6.0",
    "@hookform/resolvers": "^3.3.4",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@supabase/supabase-js": "^2.86.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/og": "^0.6.2",
    "@vidstack/react": "^0.6.15",
    "ace-builds": "^1.43.5",
    "ai": "^6.0.141",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.1.9",
    "fumadocs-core": "14.7.7",
    "fumadocs-mdx": "11.10.1",
    "fumadocs-ui": "14.7.7",
    "geist": "^1.3.1",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.378.0",
    "next": "^15.5.10",
    "next-sitemap": "^4.2.3",
    "pocketbase": "^0.26.9",
    "posthog-js": "^1.131.4",
    "react": "^18.3.1",
    "react-ace": "^11.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.4",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-social-icons": "^6.16.0",
    "react-tweet": "^3.2.1",
    "remark-gfm": "^4.0.0",
    "resend": "^6.12.3",
    "sharp": "^0.33.3",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "validator": "^13.15.23",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@eslint/js": "^9",
    "@next/bundle-analyzer": "^15.1.4",
    "@next/eslint-plugin-next": "^15",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "18.16.0",
    "@types/react": "^18.3.12",
    "@types/validator": "^13.15.10",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^56",
    "globals": "^15",
    "husky": "^9.0.11",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8",
    "webpack": "^5.104.1"
  },
  "optionalDependencies": {
    "crisp-sdk-web": "^1.0.25"
  },
  "pnpm": {
    "overrides": {
      "next": ">=15.5.10",
      "preact": ">=10.28.2",
      "webpack": ">=5.104.1",
      "diff": ">=5.2.2",
      "minimatch": ">=3.1.4",
      "serialize-javascript": ">=7.0.3"
    },
    "patchedDependencies": {
      "fumadocs-ui@14.7.7": "patches/fumadocs-ui@14.7.7.patch"
    }
  },
  "nextBundleAnalysis": {
    "budget": 358400,
    "budgetPercentIncreaseRed": 20,
    "minimumChangeThreshold": 50,
    "showDetails": true
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
